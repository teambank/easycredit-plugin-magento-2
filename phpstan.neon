# PHPStan config when running from the plugin repo (composer install in workspace).
# Requires MAGENTO_DIR (e.g. /opt/magento) and MAGENTO_VENDOR_DIR (e.g. /opt/magento/vendor).
parameters:
  magento:
    magentoRoot: %env.MAGENTO_DIR%
  bootstrapFiles:
    - phpstan-bootstrap.php
  paths:
    - .
  level: 1
  scanDirectories:
    - %env.MAGENTO_VENDOR_DIR%
  excludePaths:
    - vendor
    # Analyzed via callers only (avoids PHPStan duplicate-class false positives with factories/Magento *Helper\Data).
    - Block/Ui/Widget.php
    - BackendApi/Storage.php
    - Helper/EasyCreditData.php
    - Helper/Payment.php
    - Service/Authorization.php
    - %currentWorkingDirectory%/ecs.php
    - %currentWorkingDirectory%/rector.php
  ignoreErrors:
    - '#Use service contracts.+?QuoteIdMask#'
  reportUnmatchedIgnoredErrors: false
